{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grainlab",
  "version": "0.1.0",
  "identifier": "com.adammenges.grainlab",
  "build": {
    "frontendDist": "../ui",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grainlab",
        "width": 1080,
        "height": 720,
        "minWidth": 740,
        "minHeight": 620,
        "backgroundColor": "#0d1210",
        "transparent": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' blob: data: asset: http://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
